DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/bonsight?schema=public"

# AWS
AWS_PROFILE=bonsight-dev
AWS_REGION=us-east-1
# AWS Cognito (cmd_019)
COGNITO_USER_POOL_ID=ap-northeast-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=ap-northeast-1
# AWS Bedrock (cmd_019) — IAMロール/認証情報で自動取得のため通常不要
# AWS_ACCESS_KEY_ID=  ← 本番はECS TaskRole、開発は ~/.aws/credentials を使用
# AWS_SECRET_ACCESS_KEY=
# AWS S3 (cmd_019)
S3_BUCKET_NAME=bonsight-dev-media
CLOUDFRONT_DOMAIN=https://XXXXXXXXXX.cloudfront.net
