DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/bonsight?schema=public"

# AWS (値の取得方法は docs/aws/cognito-setup.md を参照)
AWS_PROFILE=bonsight-dev
AWS_REGION=ap-northeast-1

# AWS Cognito (JWT検証用 — 秘密情報なし、JWKSは公開鍵)
COGNITO_USER_POOL_ID=ap-northeast-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS Bedrock (IAMロール/認証情報で自動取得のため通常不要)
# AWS_ACCESS_KEY_ID=  ← 本番はECS TaskRole、開発は ~/.aws/credentials を使用
# AWS_SECRET_ACCESS_KEY=

# AWS S3 / CloudFront (presigned URL アップロード + CDN配信)
S3_BUCKET_NAME=bonsight-dev-media
CLOUDFRONT_DOMAIN=https://XXXXXXXXXX.cloudfront.net
CLOUDFRONT_DISTRIBUTION_ID=EXXXXXXXXXXXXXXXXX
# presign生成用: AWS_PROFILE=bonsight-dev (または ~/.aws/credentials の[default])

# Amazon Bedrock
BEDROCK_REGION=us-east-1
# 診断用: 画像対応モデル(Claude Sonnet 4.6等)。クォータ承認後に設定。
# AWSコンソール→Bedrock→推論プロファイルで有効なIDを確認。
BEDROCK_DIAGNOSIS_MODEL_ID=us.anthropic.claude-sonnet-4-6-XXXXXXXX-v1:0
# チャット用: テキストモデル(Nova Micro等でも可)。今すぐ確認可能。
# 例: us.amazon.nova-micro-v1:0 (クォータ不要)
BEDROCK_CHAT_MODEL_ID=us.anthropic.claude-sonnet-4-6-XXXXXXXX-v1:0
# 後方互換(未設定時のフォールバック)
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6-XXXXXXXX-v1:0
